{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "CI"],
  "globalDependencies": ["tsconfig.base.json", ".eslintrc.base.js"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "tsconfig*.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**/*.ts", "tests/**/*.ts", ".eslintrc*", "*.json"],
      "outputs": []
    },
    "boundary:check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", ".dependency-cruiser.js"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
      "outputs": [],
      "env": ["DATABASE_URL", "JWT_PRIVATE_KEY", "JWT_PUBLIC_KEY", "SESSION_SECRET", "NODE_ENV"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL", "JWT_PRIVATE_KEY", "JWT_PUBLIC_KEY", "SESSION_SECRET", "NODE_ENV"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig*.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "db:generate": { "cache": false },
    "db:migrate": { "cache": false },
    "db:seed": { "cache": false },
    "db:fresh": { "cache": false }
  }
}
