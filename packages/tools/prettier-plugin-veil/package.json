{
  "name": "@lumiarq/prettier-plugin-veil",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Prettier plugin for Veil templates (.veil.html) — framework-aware formatting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
  }
}
