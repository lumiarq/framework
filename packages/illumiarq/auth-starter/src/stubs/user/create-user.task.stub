import { defineTask } from '@lumiarq/framework';
import type { User }   from '@/modules/User/contracts/models/user.model';
import type { UserRepository, CreateUserData } from '@/modules/User/database/repositories/user.repository';

export const CreateUserTask = defineTask(
  async (input: CreateUserData, repo: UserRepository): Promise<User> =>
    repo.create(input),
);
