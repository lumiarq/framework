import { defineTask } from '@lumiarq/framework';
import type { User }   from '@/modules/User/contracts/models/user.model';
import type { UserRepository } from '@/modules/User/database/repositories/user.repository';

export const FindUserTask = defineTask(
  async (id: string, repo: UserRepository): Promise<User | null> =>
    repo.findById(id),
);
