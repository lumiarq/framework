{
  "name": "@illumiarq/query",
  "version": "1.0.0",
  "license": "MIT",
  "description": "LumiARQ query bridge — framework-agnostic loader bridge. TanStack Query is the default adapter, not a required dependency. Use SWR, Apollo, or plain fetch via @lumiarq/query/core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./solid": {
      "import": "./dist/solid/index.js",
      "types": "./dist/solid/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte/index.js",
      "types": "./dist/svelte/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "@illumiarq/core": "^1.0.0",
    "@illumiarq/http": "^1.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@tanstack/solid-query": ">=5.0.0",
    "@tanstack/vue-query": ">=5.0.0",
    "react": ">=18.0.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/vue-query": {
      "optional": true
    },
    "@tanstack/solid-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
