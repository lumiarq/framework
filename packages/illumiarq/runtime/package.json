{
  "name": "@illumiarq/runtime",
  "version": "1.0.0",
  "license": "MIT",
  "description": "LumiARQ runtime — request lifecycle, loader orchestration (parallel + deduplication), middleware pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "fast-json-stable-stringify": "^2.1.0",
    "hono": "^4.12.7",
    "@illumiarq/contracts": "^1.0.0",
    "@illumiarq/http": "^1.0.0",
    "@illumiarq/testing": "^1.0.0",
    "@illumiarq/context": "^1.0.0",
    "@illumiarq/core": "^1.0.0",
    "@illumiarq/modules": "^1.0.0",
    "@illumiarq/security": "^1.0.0",
    "@trazze/sdk": "^0.1.0"
  }
}
