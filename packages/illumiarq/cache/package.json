{
  "name": "@illumiarq/cache",
  "version": "1.0.0",
  "license": "MIT",
  "description": "LumiArq cache facade — session and in-memory drivers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
