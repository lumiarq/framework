{
  "name": "@illumiarq/veil",
  "version": "1.0.0",
  "license": "MIT",
  "description": "LumiArq Veil template  compiler and runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/patch-types.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "alpinejs": "^3.13.0"
  },
  "peerDependenciesMeta": {
    "alpinejs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
